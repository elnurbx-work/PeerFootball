generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MediaType {
  IMAGE
  VIDEO
}

enum AppLocale {
  AZ
  EN
  RU
}

enum TeamRole {
  OWNER
  CAPTAIN
  MEMBER
}

enum ClubVisibility {
  OPEN
  REQUEST_ONLY
  INVITE_ONLY
}

enum ClubRole {
  OWNER
  TD
  YTD
  PLAYER
}

enum ClubMemberStatus {
  ACTIVE
  INVITED
  REQUESTED
  LEFT
  REMOVED
}

enum ClubPermissionPolicy {
  OWNER_ONLY
  OWNER_TD
  OWNER_TD_YTD
}

enum GuestInvitePolicy {
  CLOSED
  ONLY_OWNER_TD_YTD
  PLAYERS_CAN_INVITE_FRIENDS
}

enum MatchStatus {
  DRAFT
  PENDING_OPPONENT_APPROVAL
  SCHEDULED
  LIVE
  RESULT_PENDING_CONFIRMATION
  FINISHED
  DISPUTED
  CANCELLED
}

enum MatchType {
  INTERNAL
  CLUB_VS_CLUB
}

enum MatchCategory {
  FRIENDLY
  TRAINING
  OFFICIAL
}

enum MatchSideType {
  HOME
  AWAY
  TEAM_A
  TEAM_B
}

enum MatchPlayerStatus {
  SELECTED
  INVITED
  ACCEPTED
  DECLINED
  REMOVED
}

enum FootballPosition {
  GK
  CB
  LB
  RB
  LWB
  RWB
  CDM
  CM
  CAM
  LM
  RM
  LW
  RW
  CF
  ST
  OTHER
}

enum MatchVideoProvider {
  GOOGLE_DRIVE
  YOUTUBE
  EXTERNAL
}

enum MatchVideoType {
  FULL_MATCH
  FIRST_HALF
  SECOND_HALF
  OTHER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum ProfileVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum PostVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum ConversationType {
  DIRECT
  TEAM
  MATCH
  CLUB
}

enum NotificationType {
  POST_LIKE
  POST_COMMENT
  COMMENT_REPLY
  POST_REPOST
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  MESSAGE
}

enum FeedbackStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model User {
  id                      String                 @id @default(cuid())
  name                    String?
  email                   String?                @unique
  emailVerified           DateTime?
  passwordHash            String?
  image                   String?
  coverImage              String?
  username                String?                @unique
  bio                     String?
  favoriteClub            String?
  preferredPosition       String?
  avoidedPosition         String?
  location                String?
  locale                  AppLocale              @default(AZ)
  profileVisibility       ProfileVisibility      @default(PUBLIC)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  isBanned                Boolean                @default(false)
  bannedAt                DateTime?
  banReason               String?
  posts                   Post[]
  comments                Comment[]
  likes                   PostLike[]
  following               Follow[]               @relation("Following")
  followers               Follow[]               @relation("Followers")
  sentFriendRequests      Friendship[]           @relation("FriendshipRequester")
  receivedFriendRequests  Friendship[]           @relation("FriendshipAddressee")
  blockedUsers            Block[]                @relation("Blocker")
  blockedByUsers          Block[]                @relation("Blocked")
  encryptedProfile        UserEncryptedProfile?
  conversationMemberships ConversationMember[]
  sentMessages            Message[]              @relation("MessageSender")
  receivedNotifications   Notification[]         @relation("NotificationRecipient")
  actedNotifications      Notification[]         @relation("NotificationActor")
  favoriteTeams           UserFavoriteTeam[]
  ownedTeams              Team[]
  teamMemberships         TeamMember[]
  ownedClubs              Club[]                 @relation("ClubOwner")
  deactivatedClubs        Club[]                 @relation("ClubDeactivatedBy")
  clubMemberships         ClubMember[]           @relation("ClubMemberUser")
  clubInvitesSent         ClubMember[]           @relation("ClubMemberInviter")
  clubGuestsCreated       ClubGuest[]            @relation("ClubGuestCreator")
  clubMetricDefinitions   ClubMetricDefinition[] @relation("ClubMetricCreator")
  createdMatches          Match[]                @relation("MatchCreatedBy")
  submittedMatchResults   Match[]                @relation("MatchResultSubmittedBy")
  confirmedMatchResults   Match[]                @relation("MatchResultConfirmedBy")
  matchPlayers            MatchPlayer[]          @relation("MatchPlayerUser")
  matchPlayerInvites      MatchPlayer[]          @relation("MatchPlayerInviter")
  matchVideos             MatchVideo[]           @relation("MatchVideoUploader")
  matchComments           MatchComment[]         @relation("MatchCommentAuthor")
  playerStats             PlayerStats?
  accounts                Account[]
  sessions                Session[]
  feedbacks               Feedback[]
  submittedPostReports    PostReport[]           @relation("PostReportReporter")
  receivedPostReports     PostReport[]           @relation("PostReportAuthor")
}

model UserFavoriteTeam {
  id         String   @id @default(cuid())
  userId     String
  externalId String?
  name       String
  country    String?
  league     String?
  logoUrl    String?
  badgeUrl   String?
  source     String   @default("thesportsdb")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([userId])
  @@index([name])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Feedback {
  id         String         @id @default(cuid())
  userId     String
  message    String
  status     FeedbackStatus @default(OPEN)
  adminNote  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  resolvedAt DateTime?
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model UserEncryptedProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  ciphertext String
  iv         String
  algorithm  String   @default("AES-GCM")
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id             String         @id @default(cuid())
  authorId       String
  content        String?
  visibility     PostVisibility @default(PUBLIC)
  originalPostId String?
  repostNote     String?
  ciphertext     String?
  iv             String?
  algorithm      String?        @default("AES-GCM")
  keyVersion     Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  isHidden       Boolean        @default(false)
  hiddenAt       DateTime?
  moderationNote String?
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  originalPost   Post?          @relation("PostReposts", fields: [originalPostId], references: [id], onDelete: SetNull)
  reposts        Post[]         @relation("PostReposts")
  media          PostMedia[]
  comments       Comment[]
  likes          PostLike[]
  notifications  Notification[]
  reports        PostReport[]

  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([originalPostId])
  @@index([visibility])
  @@index([isHidden, createdAt])
}

model PostReport {
  id           String       @id @default(cuid())
  postId       String
  reporterId   String
  postAuthorId String
  note         String
  status       ReportStatus @default(OPEN)
  adminNote    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  resolvedAt   DateTime?
  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter     User         @relation("PostReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  postAuthor   User         @relation("PostReportAuthor", fields: [postAuthorId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
  @@index([status, createdAt])
  @@index([postAuthorId, createdAt])
}

model PostMedia {
  id        String    @id @default(cuid())
  postId    String
  type      MediaType
  url       String
  publicId  String
  width     Int?
  height    Int?
  duration  Float?
  format    String?
  size      Int?
  order     Int
  createdAt DateTime  @default(now())
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, order])
  @@index([postId])
}

model Comment {
  id            String         @id @default(cuid())
  postId        String
  authorId      String
  parentId      String?
  content       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  notifications Notification[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([authorId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Friendship {
  id            String           @id @default(cuid())
  requesterId   String
  addresseeId   String
  status        FriendshipStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  acceptedAt    DateTime?
  requester     User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee     User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Conversation {
  id            String               @id @default(cuid())
  type          ConversationType
  clubId        String?              @unique
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  members       ConversationMember[]
  messages      Message[]
  notifications Notification[]
  club          Club?                @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ConversationMember {
  id                       String       @id @default(cuid())
  conversationId           String
  userId                   String
  encryptedConversationKey String
  keyVersion               Int          @default(1)
  joinedAt                 DateTime     @default(now())
  lastReadAt               DateTime?
  conversation             Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  senderId       String
  ciphertext     String
  iv             String
  authTag        String
  algorithm      String         @default("aes-256-gcm")
  keyVersion     Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  notifications  Notification[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id             String           @id @default(cuid())
  recipientId    String
  actorId        String?
  type           NotificationType
  postId         String?
  commentId      String?
  conversationId String?
  messageId      String?
  friendshipId   String?
  title          String?
  body           String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  recipient      User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor          User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  post           Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment        Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  friendship     Friendship?      @relation(fields: [friendshipId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt])
  @@index([actorId])
  @@index([postId])
  @@index([commentId])
  @@index([conversationId])
  @@index([type])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String
  logoUrl     String?
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  position String?
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Club {
  id                String                 @id @default(cuid())
  name              String
  slug              String                 @unique
  description       String?
  logoUrl           String?
  logoPublicId      String?
  coverUrl          String?
  coverPublicId     String?
  country           String?
  city              String?
  ownerId           String
  visibility        ClubVisibility         @default(REQUEST_ONLY)
  isActive          Boolean                @default(true)
  deactivatedAt     DateTime?
  deactivatedById   String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  owner             User                   @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  deactivatedBy     User?                  @relation("ClubDeactivatedBy", fields: [deactivatedById], references: [id], onDelete: SetNull)
  settings          ClubSettings?
  members           ClubMember[]
  guests            ClubGuest[]
  metricDefinitions ClubMetricDefinition[]
  conversation      Conversation?
  createdMatches    Match[]                @relation("MatchCreatorClub")
  homeMatches       Match[]                @relation("MatchHomeClub")
  awayMatches       Match[]                @relation("MatchAwayClub")
  matchSides        MatchSide[]

  @@index([ownerId])
  @@index([isActive])
}

model ClubSettings {
  id                          String               @id @default(cuid())
  clubId                      String               @unique
  joinApprovalPolicy          ClubPermissionPolicy @default(OWNER_TD)
  invitePermissionPolicy      ClubPermissionPolicy @default(OWNER_TD)
  matchCreatePermissionPolicy ClubPermissionPolicy @default(OWNER_TD)
  guestInvitePolicy           GuestInvitePolicy    @default(ONLY_OWNER_TD_YTD)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  club                        Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubMember {
  id          String           @id @default(cuid())
  clubId      String
  userId      String
  role        ClubRole         @default(PLAYER)
  status      ClubMemberStatus @default(REQUESTED)
  invitedById String?
  joinedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User             @relation("ClubMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User?            @relation("ClubMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
  @@index([clubId, role])
  @@index([clubId, status])
}

model ClubGuest {
  id           String            @id @default(cuid())
  clubId       String
  fullName     String
  position     FootballPosition?
  phone        String?
  note         String?
  createdById  String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  club         Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("ClubGuestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  matchPlayers MatchPlayer[]

  @@index([clubId])
}

model ClubMetricDefinition {
  id          String   @id @default(cuid())
  clubId      String
  name        String
  description String?
  order       Int
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("ClubMetricCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([clubId])
  @@index([clubId, isActive])
}

model Match {
  id                  String         @id @default(cuid())
  type                MatchType
  category            MatchCategory  @default(FRIENDLY)
  status              MatchStatus    @default(DRAFT)
  creatorClubId       String
  homeClubId          String?
  awayClubId          String?
  title               String?
  venue               String?
  startTime           DateTime
  endTime             DateTime?
  homeScore           Int?
  awayScore           Int?
  resultNote          String?
  resultSubmittedById String?
  resultSubmittedAt   DateTime?
  resultConfirmedById String?
  resultConfirmedAt   DateTime?
  disputeReason       String?
  adminDecisionNote   String?
  createdById         String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  creatorClub         Club           @relation("MatchCreatorClub", fields: [creatorClubId], references: [id], onDelete: Restrict)
  homeClub            Club?          @relation("MatchHomeClub", fields: [homeClubId], references: [id], onDelete: Restrict)
  awayClub            Club?          @relation("MatchAwayClub", fields: [awayClubId], references: [id], onDelete: Restrict)
  createdBy           User           @relation("MatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  resultSubmittedBy   User?          @relation("MatchResultSubmittedBy", fields: [resultSubmittedById], references: [id], onDelete: SetNull)
  resultConfirmedBy   User?          @relation("MatchResultConfirmedBy", fields: [resultConfirmedById], references: [id], onDelete: SetNull)
  sides               MatchSide[]
  players             MatchPlayer[]
  videos              MatchVideo[]
  goals               MatchGoal[]
  comments            MatchComment[]

  @@index([creatorClubId])
  @@index([homeClubId])
  @@index([awayClubId])
  @@index([status])
  @@index([startTime])
}

model MatchSide {
  id        String        @id @default(cuid())
  matchId   String
  clubId    String?
  name      String
  side      MatchSideType
  score     Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  match     Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  club      Club?         @relation(fields: [clubId], references: [id], onDelete: Restrict)
  players   MatchPlayer[]
  goals     MatchGoal[]

  @@unique([matchId, side])
  @@index([matchId])
}

model MatchPlayer {
  id          String            @id @default(cuid())
  matchId     String
  matchSideId String
  userId      String?
  clubGuestId String?
  guestName   String?
  position    FootballPosition?
  shirtNumber Int?
  status      MatchPlayerStatus @default(SELECTED)
  invitedById String?
  acceptedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  match       Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchSide   MatchSide         @relation(fields: [matchSideId], references: [id], onDelete: Cascade)
  user        User?             @relation("MatchPlayerUser", fields: [userId], references: [id], onDelete: Restrict)
  clubGuest   ClubGuest?        @relation(fields: [clubGuestId], references: [id], onDelete: Restrict)
  invitedBy   User?             @relation("MatchPlayerInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  goals       MatchGoal[]

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([matchSideId])
  @@index([userId])
  @@index([clubGuestId])
}

model MatchVideo {
  id               String             @id @default(cuid())
  matchId          String
  originalUrl      String
  embedUrl         String
  provider         MatchVideoProvider
  videoType        MatchVideoType     @default(FULL_MATCH)
  matchStartSecond Int                @default(0)
  publicId         String?
  title            String?
  description      String?
  uploadedById     String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @default(now()) @updatedAt
  match            Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  uploadedBy       User               @relation("MatchVideoUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([matchId])
}

model MatchGoal {
  id            String       @id @default(cuid())
  matchId       String
  matchSideId   String
  matchPlayerId String?
  playerName    String
  minute        Int?
  extraMinute   Int?
  createdAt     DateTime     @default(now())
  match         Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchSide     MatchSide    @relation(fields: [matchSideId], references: [id], onDelete: Cascade)
  matchPlayer   MatchPlayer? @relation(fields: [matchPlayerId], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@index([matchSideId])
}

model MatchComment {
  id        String         @id @default(cuid())
  matchId   String
  authorId  String
  parentId  String?
  content   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  match     Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author    User           @relation("MatchCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    MatchComment?  @relation("MatchCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   MatchComment[] @relation("MatchCommentReplies")

  @@index([matchId, createdAt])
  @@index([parentId])
}

model PlayerStats {
  id            String   @id @default(cuid())
  userId        String   @unique
  matchesPlayed Int      @default(0)
  goals         Int      @default(0)
  assists       Int      @default(0)
  preferredFoot String?
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
