generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MediaType {
  IMAGE
  VIDEO
}

enum TeamRole {
  OWNER
  CAPTAIN
  MEMBER
}

enum ClubVisibility {
  OPEN
  REQUEST_ONLY
  INVITE_ONLY
}

enum ClubRole {
  OWNER
  TD
  YTD
  PLAYER
}

enum ClubMemberStatus {
  ACTIVE
  INVITED
  REQUESTED
  LEFT
  REMOVED
}

enum ClubPermissionPolicy {
  OWNER_ONLY
  OWNER_TD
  OWNER_TD_YTD
}

enum GuestInvitePolicy {
  CLOSED
  ONLY_OWNER_TD_YTD
  PLAYERS_CAN_INVITE_FRIENDS
}

enum MatchStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum MatchParticipantStatus {
  JOINED
  WAITING
  CANCELLED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum ProfileVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum PostVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum ConversationType {
  DIRECT
  TEAM
  MATCH
}

enum NotificationType {
  POST_LIKE
  POST_COMMENT
  COMMENT_REPLY
  POST_REPOST
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  MESSAGE
}

model User {
  id                      String                @id @default(cuid())
  name                    String?
  email                   String?               @unique
  emailVerified           DateTime?
  passwordHash            String?
  image                   String?
  coverImage              String?
  username                String?               @unique
  bio                     String?
  favoriteClub            String?
  preferredPosition       String?
  avoidedPosition         String?
  location                String?
  profileVisibility       ProfileVisibility     @default(PUBLIC)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  posts                   Post[]
  comments                Comment[]
  likes                   PostLike[]
  following               Follow[]              @relation("Following")
  followers               Follow[]              @relation("Followers")
  sentFriendRequests      Friendship[]          @relation("FriendshipRequester")
  receivedFriendRequests  Friendship[]          @relation("FriendshipAddressee")
  blockedUsers            Block[]               @relation("Blocker")
  blockedByUsers          Block[]               @relation("Blocked")
  encryptedProfile        UserEncryptedProfile?
  conversationMemberships ConversationMember[]
  sentMessages            Message[]             @relation("MessageSender")
  receivedNotifications   Notification[]        @relation("NotificationRecipient")
  actedNotifications      Notification[]        @relation("NotificationActor")
  favoriteTeams           UserFavoriteTeam[]
  ownedTeams              Team[]
  teamMemberships         TeamMember[]
  ownedClubs              Club[]               @relation("ClubOwner")
  deactivatedClubs        Club[]               @relation("ClubDeactivatedBy")
  clubMemberships         ClubMember[]         @relation("ClubMemberUser")
  clubInvitesSent         ClubMember[]         @relation("ClubMemberInviter")
  clubGuestsCreated       ClubGuest[]          @relation("ClubGuestCreator")
  clubMetricDefinitions   ClubMetricDefinition[] @relation("ClubMetricCreator")
  createdMatches          Match[]
  matchParticipants       MatchParticipant[]
  playerStats             PlayerStats?
  accounts                Account[]
  sessions                Session[]
}

model UserFavoriteTeam {
  id         String   @id @default(cuid())
  userId     String
  externalId String?
  name       String
  country    String?
  league     String?
  logoUrl    String?
  badgeUrl   String?
  source     String   @default("thesportsdb")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([userId])
  @@index([name])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model UserEncryptedProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  ciphertext String
  iv         String
  algorithm  String   @default("AES-GCM")
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id             String         @id @default(cuid())
  authorId       String
  content        String?
  visibility     PostVisibility @default(PUBLIC)
  originalPostId String?
  repostNote     String?
  ciphertext     String?
  iv             String?
  algorithm      String?        @default("AES-GCM")
  keyVersion     Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  originalPost   Post?          @relation("PostReposts", fields: [originalPostId], references: [id], onDelete: SetNull)
  reposts        Post[]         @relation("PostReposts")
  media          PostMedia[]
  comments       Comment[]
  likes          PostLike[]
  notifications  Notification[]

  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([originalPostId])
  @@index([visibility])
}

model PostMedia {
  id        String    @id @default(cuid())
  postId    String
  type      MediaType
  url       String
  publicId  String
  width     Int?
  height    Int?
  duration  Float?
  format    String?
  size      Int?
  order     Int
  createdAt DateTime  @default(now())
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, order])
  @@index([postId])
}

model Comment {
  id            String         @id @default(cuid())
  postId        String
  authorId      String
  parentId      String?
  content       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  notifications Notification[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([authorId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Friendship {
  id            String           @id @default(cuid())
  requesterId   String
  addresseeId   String
  status        FriendshipStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  acceptedAt    DateTime?
  requester     User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee     User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Conversation {
  id            String               @id @default(cuid())
  type          ConversationType
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  members       ConversationMember[]
  messages      Message[]
  notifications Notification[]
}

model ConversationMember {
  id                       String       @id @default(cuid())
  conversationId           String
  userId                   String
  encryptedConversationKey String
  keyVersion               Int          @default(1)
  joinedAt                 DateTime     @default(now())
  lastReadAt               DateTime?
  conversation             Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  senderId       String
  ciphertext     String
  iv             String
  authTag        String
  algorithm      String         @default("aes-256-gcm")
  keyVersion     Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  notifications  Notification[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id             String           @id @default(cuid())
  recipientId    String
  actorId        String?
  type           NotificationType
  postId         String?
  commentId      String?
  conversationId String?
  messageId      String?
  friendshipId   String?
  title          String?
  body           String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  recipient      User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor          User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  post           Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment        Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  friendship     Friendship?      @relation(fields: [friendshipId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt])
  @@index([actorId])
  @@index([postId])
  @@index([commentId])
  @@index([conversationId])
  @@index([type])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String
  logoUrl     String?
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  matches     Match[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  position String?
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Club {
  id                String                 @id @default(cuid())
  name              String
  slug              String                 @unique
  description       String?
  logoUrl           String?
  logoPublicId      String?
  coverUrl          String?
  coverPublicId     String?
  country           String?
  city              String?
  ownerId           String
  visibility        ClubVisibility         @default(REQUEST_ONLY)
  isActive          Boolean                @default(true)
  deactivatedAt     DateTime?
  deactivatedById   String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  owner             User                   @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  deactivatedBy     User?                  @relation("ClubDeactivatedBy", fields: [deactivatedById], references: [id], onDelete: SetNull)
  settings          ClubSettings?
  members           ClubMember[]
  guests            ClubGuest[]
  metricDefinitions ClubMetricDefinition[]

  @@index([ownerId])
  @@index([isActive])
}

model ClubSettings {
  id                          String               @id @default(cuid())
  clubId                      String               @unique
  joinApprovalPolicy          ClubPermissionPolicy @default(OWNER_TD)
  invitePermissionPolicy      ClubPermissionPolicy @default(OWNER_TD)
  matchCreatePermissionPolicy ClubPermissionPolicy @default(OWNER_TD)
  guestInvitePolicy           GuestInvitePolicy    @default(ONLY_OWNER_TD_YTD)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  club                        Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubMember {
  id          String           @id @default(cuid())
  clubId      String
  userId      String
  role        ClubRole         @default(PLAYER)
  status      ClubMemberStatus @default(REQUESTED)
  invitedById String?
  joinedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User             @relation("ClubMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User?            @relation("ClubMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@index([userId])
  @@index([clubId, role])
  @@index([clubId, status])
  @@index([userId, clubId])
}

model ClubGuest {
  id          String   @id @default(cuid())
  clubId      String
  fullName    String
  position    String?
  phone       String?
  note        String?
  createdById String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("ClubGuestCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([clubId])
}

model ClubMetricDefinition {
  id          String   @id @default(cuid())
  clubId      String
  name        String
  description String?
  order       Int
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("ClubMetricCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([clubId])
  @@index([clubId, isActive])
}

model Match {
  id           String             @id @default(cuid())
  title        String
  description  String?
  location     String
  matchDate    DateTime
  maxPlayers   Int
  status       MatchStatus        @default(OPEN)
  creatorId    String
  teamId       String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  creator      User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  team         Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  participants MatchParticipant[]

  @@index([creatorId])
  @@index([teamId])
  @@index([matchDate])
}

model MatchParticipant {
  id       String                 @id @default(cuid())
  matchId  String
  userId   String
  position String
  status   MatchParticipantStatus @default(JOINED)
  joinedAt DateTime               @default(now())
  match    Match                  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])
}

model PlayerStats {
  id            String   @id @default(cuid())
  userId        String   @unique
  matchesPlayed Int      @default(0)
  goals         Int      @default(0)
  assists       Int      @default(0)
  preferredFoot String?
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
