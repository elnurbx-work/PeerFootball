DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fanpitch?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fanpitch?schema=public"

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

RESEND_API_KEY=""
EMAIL_FROM="FanPitch <no-reply@example.com>"

# Cloudinary is optional. If it is not configured, the app stores the original TheSportsDB image URL.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Required for server-side chat message encryption at rest.
# Generate with: openssl rand -base64 32
MESSAGE_ENCRYPTION_KEY=""

# Optional realtime metadata publish for chat messages. Message content is not sent in Ably events.
ABLY_API_KEY=""

# Minimal Sentry error monitoring. The build also exposes this DSN to the browser.
SENTRY_DSN=""

# Dedicated admin login. The second-factor code is sent with the Resend settings above.
ADMIN_EMAIL="elnurbx@gmial.com"
ADMIN_PASSWORD="Pass123!"

# Optional Google AdSense in-feed ads. Keep disabled until the site and ad unit are approved.
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_FEED_SLOT=
NEXT_PUBLIC_ADSENSE_FEED_LAYOUT_KEY=
NEXT_PUBLIC_ADSENSE_FEED_INTERVAL=2
NEXT_PUBLIC_ADSENSE_MAX_FEED_ADS=5
